{
  "name": "verteil-node-sdk",
  "version": "2.0.0",
  "description": "Node.js wrapper for the Verteil NDC API — airline shopping, pricing, and order management",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "bin": {
    "verteil": "./bin/verteil.js"
  },
  "types": "./types/index.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": { "optional": true },
    "@opentelemetry/api": { "optional": true },
    "prom-client": { "optional": true }
  },
  "peerDependencies": {
    "ioredis": ">=5",
    "@opentelemetry/api": ">=1",
    "prom-client": ">=14"
  },
  "keywords": [
    "verteil",
    "ndc",
    "airline",
    "travel",
    "api",
    "wrapper"
  ],
  "author": "santosdave",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "node-cache": "^5.1.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "jest": {
    "extensionsToTreatAsEsm": [".js"],
    "transform": {}
  }
}
